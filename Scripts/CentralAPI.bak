if CentralAPI then return end

dofile("CentralAPI_GUI.lua")

CentralAPI = class()

--------------------------------------------------------------------------------
--================================== Helpers =================================--
--------------------------------------------------------------------------------

local function mergeTable(target, source)
    for k, v in pairs(source) do
        if type(v) == "table" then
            target[k] = target[k] or {}
            mergeTable(target[k], v)
        else
            target[k] = v
        end
    end
end

local function checkInTable(table, value)
    for k, v in pairs(table) do
        if v == value then return true end
    end
    return false
end

local function colorToHex(color)
    local r = math.floor(color.r * 255)
    local g = math.floor(color.g * 255)
    local b = math.floor(color.b * 255)
    return string.format("%02X%02X%02X", r, g, b)
end

local function capitalize(str)
    return str:sub(1, 1):upper() .. str:sub(2)
end

function generateSettings(count)
    local settings = {}

    local syllables = {
        "zor", "tek", "ban", "qua", "flo", "rix", "mon", "vel",
        "dra", "pik", "lum", "gar", "shi", "tor", "zen", "plu",
        "vox", "kri", "nop", "yel", "fim", "wak", "jor", "sni"
    }

    local function randomName()
        local parts = math.random(2, 4)
        local name = ""

        for i = 1, parts do
            name = name .. syllables[math.random(1, #syllables)]
        end

        name = capitalize(name)
        return name
    end

    local function randFloat(min, max)
        return min + math.random() * (max - min)
    end

    local function randVec3()
        return sm.vec3.new(
            math.random(-10000, 10000)/100,
            math.random(-10000, 10000)/100,
            math.random(-10000, 10000)/100
        )
    end

    local function randColor()
        return sm.color.new(
            math.random(),
            math.random(),
            math.random()
        )
    end

    for i = 1, count do
        local setting = {
            name = randomName(),
            clientEditable = math.random() > 0.2,
            clientViewable = math.random() > 0.1
        }

        local t = math.random(1, 6)

        if t == 1 then
            setting.type = "toggle"
            setting.value = math.random() > 0.5

        elseif t == 2 then
            local minVal = math.random(0, 25)
            local maxVal = math.random(50, 500)

            setting.type = "integer"
            setting.value = math.random(minVal, maxVal)
            setting.limit = math.random() > 0.5 and {
                minValue = minVal,
                maxValue = maxVal,
                step = math.random(1, 10)
            } or nil
            setting.isSlider = math.random() > 0.3

        elseif t == 3 then
            local minVal = 0
            local maxVal = math.random(10, 100)

            setting.type = "float"
            setting.value = randFloat(minVal, maxVal)
            setting.limit = math.random() > 0.5 and {
                minValue = minVal,
                maxValue = maxVal,
                step = math.random(1, 1000) / 1000
            } or nil
            setting.isSlider = math.random() > 0.3

        elseif t == 4 then
            setting.type = "string"
            setting.value = randomName() .. "_" .. math.random(100, 999)

        elseif t == 5 then
            setting.type = "color"
            setting.value = randColor()

        elseif t == 6 then
            setting.type = "vector3"
            setting.value = randVec3()
            setting.limit = math.random() > 0.5 and {
                minValue = randVec3(),
                maxValue = randVec3(),
                step = randVec3()
            }
        end

        table.insert(settings, setting)
    end

    return settings
end

